{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toppymicros.com/schemas/thermo_credit/compute_thermo_credit_metrics.request.schema.json",
  "title": "compute_thermo_credit_metrics request",
  "type": "object",
  "additionalProperties": false,
  "required": ["region", "frequency", "observations"],
  "properties": {
    "region": {
      "type": "string",
      "enum": ["jp", "eu", "us", "custom"]
    },
    "frequency": {
      "type": "string",
      "enum": ["monthly", "quarterly"]
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "credit_total"],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "credit_total": { "type": "number" },
          "credit_real_share": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "nominal_output": { "type": "number" },
          "real_output_index": { "type": "number" },
          "price_level_index": { "type": "number" },
          "asset_price_index": { "type": "number" },
          "stress_proxy": { "type": "number" }
        }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normalize_by_output": { "type": "boolean" },
        "carry_forward_missing_real_share": { "type": "boolean" }
      }
    }
  }
}
